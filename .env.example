# Supabase pooler URL (for Vercel serverless runtime) — port 6543
# Get from: Supabase Dashboard → Project Settings → Database → Connection Pooling → URI
DATABASE_URL=

# Supabase direct URL (for migrations only) — port 5432
# Get from: Supabase Dashboard → Project Settings → Database → URI
DIRECT_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_URL=
NEXTAUTH_SECRET=
STORAGE_URL=
EMAIL_API_KEY=
EMAIL_FROM=ROCSAUT <noreply@rocsaut.ca>
CRON_SECRET=your-secret-here
SHOPIFY_TOKEN=
SHOPIFY_DOMAIN=

# Web Push (VAPID) — generate with: node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k.publicKey, k.privateKey)"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact email shown in VAPID subject (must be mailto: or https:)
VAPID_SUBJECT=mailto:exec@rocsaut.ca
