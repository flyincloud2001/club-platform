// ─────────────────────────────────────────────────────────────────────────────
// Prisma Schema — ROCSAUT Club Platform
//
// 資料庫：PostgreSQL（Supabase）
// 所有 id 使用 cuid()，時間戳記使用 @default(now()) 與 @updatedAt。
// 執行 `npx prisma generate` 更新型別，`npx prisma migrate dev` 套用遷移。
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

/// 使用者角色，對應 config.yaml roles，數字越大權限越高
enum Role {
  SUPER_ADMIN /// 超級管理員（等級 5）：跨社團最高權限
  EXEC        /// 執行委員（等級 4）：社團主要負責人
  TEAM_LEAD   /// 組長（等級 3）：各部門負責人
  MEMBER      /// 一般成員（等級 2）：已加入社團的成員
}

/// 報名狀態
enum RegistrationStatus {
  REGISTERED  /// 已成功報名
  WAITLISTED  /// 在候補名單中（活動已滿）
  CANCELLED   /// 已取消報名
}

/// 任務狀態
enum TaskStatus {
  TODO        /// 待辦，尚未開始
  IN_PROGRESS /// 進行中
  DONE        /// 已完成
}

/// 任務群組狀態
enum TaskGroupStatus {
  ACTIVE    /// 進行中
  COMPLETED /// 已完成
  ARCHIVED  /// 已封存
}

/// 任務群組成員角色
enum TaskGroupRole {
  LEADER /// 群組負責人
  MEMBER /// 一般成員
}

// ─────────────────────────────────────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────────────────────────────────────

/// 使用者表
/// 透過 NextAuth Google OAuth 登入，email 必須屬於允許的網域（mail.utoronto.ca / utoronto.ca）
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  /// 大頭貼 URL，來自 Google 帳號，可為 null
  image         String?
  /// NextAuth：email 驗證時間（Magic Link 用；Google OAuth 登入時為 null）
  emailVerified DateTime?
  /// 使用者在社團中的角色
  role          Role      @default(MEMBER)
  /// 所屬部門（可為 null，尚未分配或為 exec 層級）
  departmentId  String?
  department    Department? @relation(fields: [departmentId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  /// NextAuth：OAuth 帳號關聯（一個使用者可連結多個 OAuth provider）
  accounts      Account[]
  /// NextAuth：資料庫 session（使用資料庫 session 策略時使用）
  sessions      Session[]
  /// 該使用者的所有活動報名記錄
  registrations Registration[]
  /// 該使用者被指派的任務
  assignedTasks Task[]           @relation("TaskAssignee")
  /// 該使用者在討論區發表的留言（匿名留言時 authorId 為 null）
  comments      Comment[]
  /// 該使用者建立的公告
  announcements     Announcement[]
  /// 該使用者已讀的公告記錄
  announcementReads AnnouncementRead[]
  /// 該使用者所屬的任務群組（中間表）
  taskGroups        TaskGroupMember[]
  /// 該使用者建立的任務群組
  createdTaskGroups TaskGroup[]      @relation("TaskGroupCreator")
  /// 該使用者建立的投票
  createdVotes      Vote[]           @relation("VoteCreator")
  /// 該使用者的投票回應
  voteResponses     VoteResponse[]
}

/// NextAuth：OAuth 帳號表
/// 儲存每個 OAuth provider 的 access_token / refresh_token 等憑證
/// 一個 User 可擁有多個 Account（例如同時連結 Google 和 GitHub）
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// 同一 provider 下每個帳號 ID 唯一
  @@unique([provider, providerAccountId])
}

/// NextAuth：資料庫 Session 表
/// 使用資料庫 session 策略時，每次登入在此建立一筆 session 記錄
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// NextAuth：Email 驗證 Token 表
/// 用於 Magic Link / Email 登入（本專案目前未啟用，但 adapter 需要此表）
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// 部門表（取代原 Team，專職管理社團組織架構）
/// slug 對應 config.yaml teams[].id，例如 "event"、"marketing"、"operation"
model Department {
  id          String   @id @default(cuid())
  /// 唯一識別符，對應 config.yaml 的 team id
  slug        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  /// 該部門的所有成員
  members User[]
}

/// 活動表
/// 所有公開或內部活動的主要資料，建立時自動生成對應的 Discussion
model Event {
  id          String    @id @default(cuid())
  title       String
  description String?
  /// 活動開始時間
  startAt     DateTime
  /// 活動結束時間（可為 null，例如不限時的線上活動）
  endAt       DateTime?
  location    String?
  /// 活動容量上限（null 表示不限人數）
  capacity    Int?
  /// 是否已對外發布；false 代表草稿狀態
  published   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  /// 該活動的所有報名記錄
  registrations Registration[]
  /// 每個活動對應一個討論區（一對一關係）
  discussion    Discussion?
}

/// 報名表
/// 記錄使用者對活動的報名、候補或取消狀態，以及出席打卡時間
model Registration {
  id      String             @id @default(cuid())
  userId  String
  user    User               @relation(fields: [userId], references: [id])
  eventId String
  event   Event              @relation(fields: [eventId], references: [id])
  status  RegistrationStatus @default(REGISTERED)
  /// 出席打卡時間（QR Code 或人工確認時填入，null 代表未出席或尚未打卡）
  attendedAt DateTime?
  createdAt  DateTime        @default(now())

  /// 同一使用者不能重複報名同一活動
  @@unique([userId, eventId])
}

/// 討論區表
/// 每個活動自動生成一個討論區，作為活動前後的溝通空間
/// 可選擇性關聯任務群組（供社團層級討論使用）
model Discussion {
  id          String     @id @default(cuid())
  /// 關聯的活動（唯一，一對一；TaskGroup 專屬討論區時為 null）
  eventId     String?    @unique
  event       Event?     @relation(fields: [eventId], references: [id])
  /// 關聯的任務群組（TaskGroup 專屬討論區時必填，活動討論區時可選）
  taskGroupId String?
  taskGroup   TaskGroup? @relation(fields: [taskGroupId], references: [id])
  createdAt   DateTime   @default(now())

  /// 該討論區的所有留言
  comments Comment[]
}

/// 留言表
/// 支援具名留言與匿名留言（isAnonymous = true 時 authorId 應為 null）
model Comment {
  id           String     @id @default(cuid())
  discussionId String
  discussion   Discussion @relation(fields: [discussionId], references: [id])
  /// 留言作者（匿名時為 null）
  authorId     String?
  author       User?      @relation(fields: [authorId], references: [id])
  content      String
  /// 是否為匿名留言
  isAnonymous  Boolean    @default(false)
  createdAt    DateTime   @default(now())
}

/// 公告表
/// 由管理員發布的社團公告，成員可瀏覽並標記已讀
model Announcement {
  id        String             @id @default(cuid())
  title     String
  content   String
  published Boolean            @default(false)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  authorId  String
  author    User               @relation(fields: [authorId], references: [id])
  reads     AnnouncementRead[]
}

/// 公告已讀記錄表
/// 記錄每位成員對每則公告的已讀狀態，避免重複標記
model AnnouncementRead {
  id             String       @id @default(cuid())
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  readAt         DateTime     @default(now())

  @@unique([announcementId, userId])
}

/// 任務群組表
/// 跨部門的專案群組，由 VP 或 President 建立，成員可跨部門加入
/// 每個群組包含任務、討論區和投票
model TaskGroup {
  id          String          @id @default(cuid())
  name        String
  description String?
  status      TaskGroupStatus @default(ACTIVE)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  /// 建立者（應為 VP 或 President，權限驗證在 API 層）
  createdById String
  createdBy   User            @relation("TaskGroupCreator", fields: [createdById], references: [id])

  /// 群組成員（多對多中間表）
  members     TaskGroupMember[]
  /// 該群組的所有任務
  tasks       Task[]
  /// 該群組的所有討論區
  discussions Discussion[]
  /// 該群組的所有投票
  votes       Vote[]
}

/// 任務群組成員表（多對多中間表）
/// 記錄使用者與任務群組的關係及其群組內角色
model TaskGroupMember {
  id          String        @id @default(cuid())
  taskGroupId String
  taskGroup   TaskGroup     @relation(fields: [taskGroupId], references: [id])
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  role        TaskGroupRole @default(MEMBER)
  joinedAt    DateTime      @default(now())

  /// 同一使用者在同一群組只能有一筆記錄
  @@unique([taskGroupId, userId])
}

/// 任務表
/// 隸屬於任務群組，可指派給個人
model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  /// 任務所屬群組（必填）
  taskGroupId String
  taskGroup   TaskGroup  @relation(fields: [taskGroupId], references: [id])
  /// 任務負責人（可為 null，尚未指派）
  assigneeId  String?
  assignee    User?      @relation("TaskAssignee", fields: [assigneeId], references: [id])
  status       TaskStatus  @default(TODO)
  /// 截止日期（可為 null）
  dueAt        DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

/// 投票表
/// 任務群組內的決策投票，由群組成員發起
model Vote {
  id          String    @id @default(cuid())
  title       String
  description String?
  taskGroupId String
  taskGroup   TaskGroup @relation(fields: [taskGroupId], references: [id])
  createdById String
  createdBy   User      @relation("VoteCreator", fields: [createdById], references: [id])
  /// 投票關閉時間（null 代表尚未關閉，仍可投票）
  closedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  /// 該投票的所有選項
  options VoteOption[]
}

/// 投票選項表
/// 每個投票可有多個選項，成員對每個選項最多投一票
model VoteOption {
  id     String @id @default(cuid())
  voteId String
  vote   Vote   @relation(fields: [voteId], references: [id])
  label  String

  /// 該選項的所有回應
  responses VoteResponse[]
}

/// 投票回應表
/// 記錄使用者對投票選項的回應，每人每選項只能投一次
model VoteResponse {
  id           String     @id @default(cuid())
  voteOptionId String
  voteOption   VoteOption @relation(fields: [voteOptionId], references: [id])
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  createdAt    DateTime   @default(now())

  /// 同一使用者對同一選項只能投一票
  @@unique([voteOptionId, userId])
}

/// 贊助商表
/// 儲存贊助商的基本資料，歷年贊助記錄另存於 SponsorHistory
model Sponsor {
  id          String           @id @default(cuid())
  name        String
  logoUrl     String?
  website     String?
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  histories   SponsorHistory[]
}

/// 贊助歷史記錄表
/// 記錄贊助商每年的贊助等級（tier），同一贊助商同一年份唯一
model SponsorHistory {
  id        String   @id @default(cuid())
  sponsorId String
  sponsor   Sponsor  @relation(fields: [sponsorId], references: [id], onDelete: Cascade)
  year      Int
  tier      String
  createdAt DateTime @default(now())

  @@unique([sponsorId, year])
}
