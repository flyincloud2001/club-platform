// ─────────────────────────────────────────────────────────────────────────────
// Prisma Schema — ROCSAUT Club Platform
//
// 資料庫：PostgreSQL（Supabase）
// 所有 id 使用 cuid()，時間戳記使用 @default(now()) 與 @updatedAt。
// 執行 `npx prisma generate` 更新型別，`npx prisma migrate dev` 套用遷移。
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

/// 使用者角色，對應 config.yaml roles，數字越大權限越高
enum Role {
  SUPER_ADMIN /// 超級管理員（等級 5）：跨社團最高權限
  EXEC        /// 執行委員（等級 4）：社團主要負責人
  TEAM_LEAD   /// 組長（等級 3）：各部門負責人
  MEMBER      /// 一般成員（等級 2）：已加入社團的成員
}

/// 報名狀態
enum RegistrationStatus {
  REGISTERED  /// 已成功報名
  WAITLISTED  /// 在候補名單中（活動已滿）
  CANCELLED   /// 已取消報名
}

/// 任務狀態
enum TaskStatus {
  TODO        /// 待辦，尚未開始
  IN_PROGRESS /// 進行中
  DONE        /// 已完成
}

// ─────────────────────────────────────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────────────────────────────────────

/// 使用者表
/// 透過 NextAuth Google OAuth 登入，email 必須屬於允許的網域（mail.utoronto.ca / utoronto.ca）
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  /// 大頭貼 URL，來自 Google 帳號，可為 null
  image     String?
  /// 使用者在社團中的角色
  role      Role     @default(MEMBER)
  /// 所屬部門（可為 null，尚未分配或為 exec 層級）
  teamId    String?
  team      Team?    @relation(fields: [teamId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// NextAuth：OAuth 帳號關聯（一個使用者可連結多個 OAuth provider）
  accounts      Account[]
  /// NextAuth：資料庫 session（使用資料庫 session 策略時使用）
  sessions      Session[]
  /// 該使用者的所有活動報名記錄
  registrations Registration[]
  /// 該使用者被指派的任務
  tasks         Task[]          @relation("AssignedTasks")
  /// 該使用者在討論區發表的留言（匿名留言時 authorId 為 null）
  comments      Comment[]
}

/// NextAuth：OAuth 帳號表
/// 儲存每個 OAuth provider 的 access_token / refresh_token 等憑證
/// 一個 User 可擁有多個 Account（例如同時連結 Google 和 GitHub）
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// 同一 provider 下每個帳號 ID 唯一
  @@unique([provider, providerAccountId])
}

/// NextAuth：資料庫 Session 表
/// 使用資料庫 session 策略時，每次登入在此建立一筆 session 記錄
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// NextAuth：Email 驗證 Token 表
/// 用於 Magic Link / Email 登入（本專案目前未啟用，但 adapter 需要此表）
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// 部門／團隊表
/// slug 對應 config.yaml teams[].id，例如 "event"、"marketing"、"operation"
model Team {
  id          String  @id @default(cuid())
  /// 唯一識別符，對應 config.yaml 的 team id
  slug        String  @unique
  name        String
  description String?

  /// 該部門的所有成員
  members User[]
  /// 指派給該部門的任務
  tasks   Task[]
}

/// 活動表
/// 所有公開或內部活動的主要資料，建立時自動生成對應的 Discussion
model Event {
  id          String    @id @default(cuid())
  title       String
  description String?
  /// 活動開始時間
  startAt     DateTime
  /// 活動結束時間（可為 null，例如不限時的線上活動）
  endAt       DateTime?
  location    String?
  /// 活動容量上限（null 表示不限人數）
  capacity    Int?
  /// 是否已對外發布；false 代表草稿狀態
  published   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  /// 該活動的所有報名記錄
  registrations Registration[]
  /// 每個活動對應一個討論區（一對一關係）
  discussion    Discussion?
}

/// 報名表
/// 記錄使用者對活動的報名、候補或取消狀態，以及出席打卡時間
model Registration {
  id      String             @id @default(cuid())
  userId  String
  user    User               @relation(fields: [userId], references: [id])
  eventId String
  event   Event              @relation(fields: [eventId], references: [id])
  status  RegistrationStatus @default(REGISTERED)
  /// 出席打卡時間（QR Code 或人工確認時填入，null 代表未出席或尚未打卡）
  attendedAt DateTime?
  createdAt  DateTime        @default(now())

  /// 同一使用者不能重複報名同一活動
  @@unique([userId, eventId])
}

/// 討論區表
/// 每個活動自動生成一個討論區，作為活動前後的溝通空間
/// 也可作為任務指派的來源（Task.discussionId）
model Discussion {
  id        String   @id @default(cuid())
  /// 關聯的活動（唯一，一對一）
  eventId   String   @unique
  event     Event    @relation(fields: [eventId], references: [id])
  createdAt DateTime @default(now())

  /// 該討論區的所有留言
  comments Comment[]
  /// 從此討論區衍生出的任務
  tasks    Task[]
}

/// 留言表
/// 支援具名留言與匿名留言（isAnonymous = true 時 authorId 應為 null）
model Comment {
  id           String     @id @default(cuid())
  discussionId String
  discussion   Discussion @relation(fields: [discussionId], references: [id])
  /// 留言作者（匿名時為 null）
  authorId     String?
  author       User?      @relation(fields: [authorId], references: [id])
  content      String
  /// 是否為匿名留言
  isAnonymous  Boolean    @default(false)
  createdAt    DateTime   @default(now())
}

/// 任務表
/// 用於追蹤社團內部工作項目，可指派給個人或部門
/// 也可從討論區（活動討論）直接指派，方便將討論轉化為行動
model Task {
  id           String     @id @default(cuid())
  title        String
  description  String?
  /// 任務負責人（可為 null，尚未指派）
  assigneeId   String?
  assignee     User?      @relation("AssignedTasks", fields: [assigneeId], references: [id])
  /// 負責部門（可為 null，跨部門任務）
  teamId       String?
  team         Team?      @relation(fields: [teamId], references: [id])
  /// 來源討論區（若任務由活動討論衍生，記錄此關聯）
  discussionId String?
  discussion   Discussion? @relation(fields: [discussionId], references: [id])
  status       TaskStatus  @default(TODO)
  /// 截止日期（可為 null）
  dueAt        DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}
